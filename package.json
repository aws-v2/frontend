{
  "name": "aws-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write --experimental-cli src/",
    "test": "vitest run",
    "test:unit": "vitest run \"**/*.unit.test.ts\"",
    "test:api": "vitest run \"**/*.api.test.ts\"",
    "test:e2e": "vitest run \"**/*.e2e.test.ts\"",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",


    "test:coverage": "vitest run --coverage"

  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/three": "^0.182.0",
    "axios": "^1.13.2",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.574.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.3",
    "pinia": "^3.0.4",
    "three": "^0.182.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "xterm": "^5.3.0",
    "xterm-addon-attach": "^0.9.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitejs/plugin-vue-jsx": "^5.1.3",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "prettier": "3.7.4",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.1"
  }
}
